{
  "name": "edwson-design-system",
  "version": "1.11.0",
  "description": "Machine-readable token contract for the Edwson Design System. Single source of truth consumed by code (build), Storybook (docs), and AI agents (MCP). Editing a value here propagates to every layer; agents reference token names, never raw values.",
  "color": {
