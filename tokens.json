  "type": {
    "font": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "mono": "'SF Mono', 'Fira Code', 'Courier New', monospace",
    "scale": {
      "xs": "0.72rem",
      "sm": "0.82rem",
      "base": "0.92rem",
      "lg": "1.1rem",
